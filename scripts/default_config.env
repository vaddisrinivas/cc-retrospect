# cc-analyze configuration
# Copy to ~/.cc-analyze/config.env and modify as needed.

# Data directories
# CC_ANALYZE_DATA_DIR=~/.cc-analyze
# CC_ANALYZE_CLAUDE_DIR=~/.claude

# Opus pricing ($/MTok)
PRICING_OPUS_INPUT_PER_MTOK=15.0
PRICING_OPUS_OUTPUT_PER_MTOK=75.0
PRICING_OPUS_CACHE_CREATE_PER_MTOK=18.75
PRICING_OPUS_CACHE_READ_PER_MTOK=1.50

# Sonnet pricing ($/MTok)
PRICING_SONNET_INPUT_PER_MTOK=3.0
PRICING_SONNET_OUTPUT_PER_MTOK=15.0

# Haiku pricing ($/MTok)
PRICING_HAIKU_INPUT_PER_MTOK=0.80
PRICING_HAIKU_OUTPUT_PER_MTOK=4.0

# Thresholds
THRESHOLD_LONG_SESSION_MINUTES=120
THRESHOLD_LONG_SESSION_MESSAGES=200
THRESHOLD_MEGA_PROMPT_CHARS=1000
THRESHOLD_MAX_SUBAGENTS=10
THRESHOLD_DAILY_COST_WARNING=500

# Waste detection domains (comma-separated)
WASTE_WEBFETCH_DOMAINS=github.com,api.github.com
